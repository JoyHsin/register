# =====================================================
# OpenAI 自动注册脚本 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# =====================================================

# ===== 代理（可选）=====
# HTTP_PROXY="http://127.0.0.1:7890"
# HTTPS_PROXY="http://127.0.0.1:7890"

# ===== 邮箱提供商 =====
# auto（默认）: 有 CUSTOM_EMAIL_DOMAIN 则优先走自定义域名，否则用公共临时邮箱
# custom: 强制使用自定义域名 + QQ IMAP
# tempmail / gptmail: 强制使用公共临时邮箱
MAIL_PROVIDER="custom"

# ===== 自定义域名邮箱（Cloudflare 转发 → QQ 邮箱）=====
# 邮箱格式：{随机N位字母数字}{CUSTOM_EMAIL_SUFFIX}@CUSTOM_EMAIL_DOMAIN
# 例如：SUFFIX="_bot" → 生成 abc123_bot@yourdomain.com
CUSTOM_EMAIL_DOMAIN="yourdomain.com"
CUSTOM_EMAIL_SUFFIX="_bot"       # 可选，留空则纯随机
CUSTOM_EMAIL_RANDOM_LENGTH="6"   # 随机部分长度，默认 6

# ===== QQ 邮箱 IMAP（Cloudflare 转发的目标收件箱）=====
# 需在 QQ 邮箱 → 设置 → 账户 → 开启 IMAP/SMTP → 生成授权码
QQ_IMAP_HOST="imap.qq.com"
QQ_IMAP_PORT="993"
QQ_IMAP_USER="yourqq@qq.com"
QQ_IMAP_PASS="your_qq_authorization_code"   # 授权码，非 QQ 密码
QQ_IMAP_FOLDER="INBOX"

# ===== 运行行为控制 =====
EMAIL_TIMEOUT="900"           # 单次等待邮件的最大秒数（默认 900 = 15 分钟）
OTP_RESEND_INTERVAL="300"     # 超过多少秒没收到验证码则自动重发（默认 300 = 5 分钟）
SLEEP_MIN="20"                # 两次注册之间最小休息秒数（默认 5）
SLEEP_MAX="45"                # 两次注册之间最大休息秒数（默认 30）
# RUN_ONCE="false"            # 设为 true 则只运行一次（等同于 --once）

# ===== CPA 上传与清理 =====
CPA_BASE_URL="https://your-cpa-host.com"
CPA_TOKEN="your_cpa_bearer_token"
# 注册成功后自动上传 token
CPA_UPLOAD="true"
# 注册后自动清理失效账号（需 aiohttp，即 uv sync --extra cpa）
CPA_CLEAN="true"
# 目标有效 token 数，达到后自动休眠（默认 300）
CPA_TARGET_COUNT="100"
# 清理并发数（默认 1）
CPA_WORKERS="1"
# 单请求超时秒数（默认 12） 
CPA_TIMEOUT="12"
# 清理重试次数（默认 1）
CPA_RETRIES="1"
# 用量超过此百分比则视为失效（默认 95）
CPA_USED_THRESHOLD="95"
# 上传成功后删除本地 token 文件和 accounts.txt 对应行
PRUNE_LOCAL="true"

# ===== Sub2API 自动上传（可选，推荐使用全局 Admin API Key）=====
# SUB2API_BASE_URL="http://127.0.0.1:8080"
# SUB2API_ADMIN_API_KEY="sub2adm_xxx"
# SUB2API_GROUP_IDS="2"
# AUTO_UPLOAD_SUB2API="true"

# 兼容旧方式：没有 Admin API Key 时，可用后台邮箱密码登录换 Bearer
# SUB2API_EMAIL="admin@example.com"
# SUB2API_PASSWORD="your_password"
# SUB2API_BEARER=""
